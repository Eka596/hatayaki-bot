# Discord Bot Token
TOKEN=your_bot_token_here

# Discord User ID of the bot owner
OWNER_ID=your_discord_id

# Logging mode: debug or production
LOG_MODE=debug

# AI mode: ai or json
AI_MODE=ai

# URL of local LLM (LM Studio)
AI_API_URL=http://localhost:1234/v1/chat/completions

# Model name (optional)
AI_MODEL=local-model